{
  "expo": {
    "name": "PaedsResus",
    "slug": "paeds-resus",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/paeds-resus",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "paeds-resus",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paedsresus.app",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "NSMicrophoneUsageDescription": "Used for voice commands during resuscitation",
        "NSBluetoothAlwaysUsageDescription": "Used to connect to pulse oximeters for real-time SpO₂ monitoring",
        "NSBluetoothPeripheralUsageDescription": "Used to connect to pulse oximeters for real-time SpO₂ monitoring"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.paedsresus.app",
      "permissions": [
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_SCAN",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-keep-awake",
      [
        "expo-updates",
        {
          "username": "karuejob-max"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0f172a",
          "sounds": ["./assets/alert.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "paeds-resus-app"
      }
    }
  }
}
