# Copy this file to .env and fill in the values.
# Required for Create account and any feature that uses the database.

# MySQL connection string. Examples:
#   Local MySQL:    mysql://USER:PASSWORD@localhost:3306/paeds_resus
#   Aiven/cloud:    use the URL from your provider (often includes ?ssl-mode=REQUIRED)
DATABASE_URL=

# Required for sign-in sessions (use a long random string, e.g. 32+ characters)
JWT_SECRET=

# Optional: base URL of the app (defaults work for local dev)
# APP_BASE_URL=http://localhost:3000

# Optional: auth mode (email = email/password; other = OAuth)
# AUTH_MODE=email

# Optional: platform admin (use your login openId so you get role=admin and see Admin portal)
# For email login, openId is email:your@email.com — use the same email you sign in with
# OWNER_OPEN_ID=email:admin@example.com

# Optional: session max age in milliseconds (e.g. 1800000 = 30 min). If unset, sessions last 1 year.
# SESSION_MAX_AGE_MS=1800000
