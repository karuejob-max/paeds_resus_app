# Copy this file to .env and fill in the values.
# Required for Create account and any feature that uses the database.

# MySQL connection string. Examples:
#   Local MySQL:    mysql://USER:PASSWORD@localhost:3306/paeds_resus
#   Aiven/cloud:    use the URL from your provider (often includes ?ssl-mode=REQUIRED)
# If Aiven shows ER_ACCESS_DENIED after a password reset, copy the full new URI from the console (old .env is stale).
# Test without migrating: pnpm run db:test-connection
DATABASE_URL=

# Required for sign-in sessions (use a long random string, e.g. 32+ characters)
JWT_SECRET=

# Optional: base URL of the app (defaults work for local dev)
# APP_BASE_URL=http://localhost:3000

# Client build: if www. does not serve /api/trpc (split static + API), set full tRPC URL for Vite build
# VITE_TRPC_URL=https://paedsresus.com/api/trpc

# Optional: auth mode (email = email/password; other = OAuth)
# AUTH_MODE=email

# Optional: platform admin (use your login openId so you get role=admin and see Admin portal)
# For email login, openId is email:your@email.com — use the same email you sign in with
# OWNER_OPEN_ID=email:admin@example.com

# Optional: session max age in milliseconds (e.g. 1800000 = 30 min). If unset, sessions last 1 year.
# SESSION_MAX_AGE_MS=1800000

# --- M-Pesa callback hardening (production) ---
# Comma-separated IPv4 addresses allowed to POST /api/payment/callback (and legacy /api/mpesa/callback) (MPESA-7). Empty = allow all.
# Use Safaricom’s documented callback IPs when available. Set TRUST_PROXY when behind a reverse proxy.
# MPESA_CALLBACK_IP_ALLOWLIST=
# TRUST_PROXY=true

# Daraja / STK (see README or deployment docs)
# Preferred: sandbox vs production (also accepts prod/live and dev/test aliases)
# Set to 1 only for local/UI tests without Daraja — never in production (no real STK prompt).
# MPESA_USE_MOCK=1
#
# MPESA_ENVIRONMENT=sandbox
# Production Daraja keys: MUST set MPESA_ENVIRONMENT=production or requests hit sandbox hosts and fail.
# Legacy alias (optional): MPESA_ENV=production — ignored if MPESA_ENVIRONMENT is set
# MPESA_ENV=
# Full STK callback URL (must match Daraja portal). You may set only the origin; /api/payment/callback is appended:
# MPESA_CALLBACK_URL=https://paedsresus.com
# DARAJA_CONSUMER_KEY=
# DARAJA_CONSUMER_SECRET=
# MPESA_PAYBILL=
# MPESA_PASSKEY=
# MPESA_ACCOUNT=
# CALLBACK_URL=https://your-domain.com

# One-off DB migration: adds clinicalReferrals.facilityContactEmail if missing
# pnpm run db:apply-0025
#
# One-off DB migration: adds certificates.renewalReminderSentAt if missing (fixes Render "Unknown column renewalReminderSentAt")
# pnpm run db:apply-0026
#
# B2B: users.instructorApprovedAt (approved session instructors)
# pnpm run db:apply-0027

# Cron (reminders + INST-14 analytics rollup + HI-CERT-1 certificate renewal emails). Production starts scheduler automatically; set in dev if needed:
# ENABLE_SCHEDULER=1
