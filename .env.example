# Copy this file to .env and fill in the values.
# NEVER commit .env — gitignored; secrets live on your machine and Render env only.
# Required for Create account and any feature that uses the database.

# MySQL connection string. Examples:
#   Local MySQL:    mysql://USER:PASSWORD@localhost:3306/paeds_resus
#   Aiven/cloud:    use the URL from your provider (often includes ?ssl-mode=REQUIRED)
# If Aiven shows ER_ACCESS_DENIED after a password reset, copy the full new URI from the console (old .env is stale).
# Test without migrating: pnpm run db:test-connection
DATABASE_URL=

# Required for sign-in sessions (use a long random string, e.g. 32+ characters)
JWT_SECRET=

# Optional: only if you call securityService.encryptData in production (min 24 chars). Otherwise omit.
# SECURITY_SERVICE_SECRET=
# Optional salt for scrypt derivation (defaults if unset)
# SECURITY_SERVICE_SALT=

# Optional: base URL of the app (defaults work for local dev)
# APP_BASE_URL=http://localhost:3000
#
# Certificate PDF signatory (defaults: Job Karue / Course Director)
# CERTIFICATE_SIGNATORY_NAME=Job Karue
# CERTIFICATE_SIGNATORY_TITLE=Course Director
#
# --- Transactional email (password reset, etc.) — see server/email-service.ts ---
# Production on Render: set at least one provider. Password reset uses the shared `sendEmail` helper.
#
# Option A — Force AWS SES (recommended if your domain is verified in SES):
# EMAIL_PROVIDER=ses
# AWS_REGION=us-east-1   # must match the region where your SES identity is verified
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# SES_FROM_EMAIL=noreply@your-verified-domain.com   # must be a verified identity in SES (same region)
# SES_REPLY_TO_EMAIL=support@your-domain.com        # optional; defaults to paedsresus254@gmail.com
#
# Option B — SendGrid:
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=...
# SENDGRID_FROM_EMAIL=noreply@your-domain.com     # sender allowed in SendGrid
#
# If EMAIL_PROVIDER is unset: SendGrid is used when SENDGRID_API_KEY is set; otherwise SES is used
# when both AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are set.
#
# Common reasons users get no reset email:
# - Wrong default: SENDGRID_API_KEY set but invalid → remove it or set EMAIL_PROVIDER=ses (SendGrid failure now falls back to SES when AWS creds exist).
# - EMAIL_PROVIDER unset + broken SendGrid key: same as above — prefer EMAIL_PROVIDER=ses on Render.
# - SES_FROM_EMAIL / Source not verified in the same region as AWS_REGION.
# - APP_BASE_URL unset on Render → reset link still sent but may point at localhost (set to https://www.yoursite.com).

# Client build: if www. does not serve /api/trpc (split static + API), set full tRPC URL for Vite build
# VITE_TRPC_URL=https://paedsresus.com/api/trpc

# Optional: auth mode (email = email/password; other = OAuth)
# AUTH_MODE=email

# Optional: platform admin (use your login openId so you get role=admin and see Admin portal)
# For email login, openId is email:your@email.com — use the same email you sign in with
# OWNER_OPEN_ID=email:admin@example.com

# Platform ops email alerts (hourly cron + manual run from /admin/ops). Comma-separated recipients.
# Falls back to OWNER_EMAIL or platform owner inbox if unset.
# ADMIN_ALERT_EMAIL=ops@your-hospital.org,paedsresus254@gmail.com

# Optional: session max age in milliseconds (e.g. 1800000 = 30 min). If unset, sessions last 1 year.
# Production: set explicitly when leadership locks policy (PSOT §11) — see docs/DEPLOYMENT_SESSION_AND_STAGING.md
# Recommended for production (30 min): SESSION_MAX_AGE_MS=1800000
# Unset = 1 year (legacy default in server/_core/env.ts)
SESSION_MAX_AGE_MS=1800000

# Optional: expose mock/planning tRPC routers in production (demo dashboards; not clinical). Default off in production.
# ENABLE_ASPIRATIONAL_APIS=true

# Client: show simulated ML/demo dashboards in production builds (must match server flag for APIs).
# VITE_EXPOSE_ASPIRATIONAL_APIS=true

# Tests: `pnpm run test:unit` — fast gate, no DATABASE_URL required (see vitest.unit.config.ts).
#        `pnpm run test:clinical` — Resus/clinical engine tests only (vitest.clinical.config.ts).
#        `pnpm test` — release gate (unit + clinical + api).
#        `pnpm run test:all` — full Vitest suite (may require DATABASE_URL; not a merge gate).

# --- M-Pesa callback hardening (production) ---
# Comma-separated IPv4 addresses allowed to POST /api/payment/callback (and legacy /api/mpesa/callback) (MPESA-7). Empty = allow all.
# Use Safaricom’s documented callback IPs when available. Set TRUST_PROXY when behind a reverse proxy.
# MPESA_CALLBACK_IP_ALLOWLIST=
# TRUST_PROXY=true

# Daraja / STK (see README or deployment docs)
# Preferred: sandbox vs production (also accepts prod/live and dev/test aliases)
# Set to 1 only for local/UI tests without Daraja — never in production (no real STK prompt).
# MPESA_USE_MOCK=1
#
# MPESA_ENVIRONMENT=sandbox
# Production Daraja keys: MUST set MPESA_ENVIRONMENT=production or requests hit sandbox hosts and fail.
# Legacy alias (optional): MPESA_ENV=production — ignored if MPESA_ENVIRONMENT is set
# MPESA_ENV=
# Full STK callback URL (must match Daraja portal). You may set only the origin; /api/payment/callback is appended:
# MPESA_CALLBACK_URL=https://paedsresus.com
# DARAJA_CONSUMER_KEY=
# DARAJA_CONSUMER_SECRET=
# MPESA_PAYBILL=
# MPESA_PASSKEY=
# MPESA_ACCOUNT=
# CALLBACK_URL=https://your-domain.com

# ResusGPS fellowship window: if true, users with no resusGpsAccessExpiresAt cannot open ResusGPS until they complete a micro-course (default: off; legacy accounts stay open).
# RESUSGPS_STRICT_FELLOWSHIP_WINDOW=0

# One-off DB migration: adds clinicalReferrals.facilityContactEmail if missing
# pnpm run db:apply-0025
#
# One-off DB migration: adds certificates.renewalReminderSentAt if missing (fixes Render "Unknown column renewalReminderSentAt")
# pnpm run db:apply-0026
#
# B2B: users.instructorApprovedAt (approved session instructors)
# pnpm run db:apply-0027

# Cron (reminders + INST-14 analytics rollup + HI-CERT-1 certificate renewal emails). Production starts scheduler automatically; set in dev if needed:
# ENABLE_SCHEDULER=1

# --- Staging environment (Render + Aiven — see docs/STAGING_GO_LIVE_CHECKLIST.md) ---
# Use a SEPARATE database and JWT secret from production. Never point staging at production DATABASE_URL.
# STAGING_DATABASE_URL=mysql://...   # local .env.staging only — do not commit
# APP_BASE_URL=https://staging.paedsresus.com
# MPESA_ENVIRONMENT=sandbox
# MPESA_USE_MOCK=1                   # optional: skip Daraja on staging when payment QA not needed

# --- STK latency (host must stay warm) ---
# Free tiers often spin down after idle: first payment after quiet period can take 1–2+ minutes.
# Fix: paid "always on" / min instances, OR ping GET https://your-domain/api/health every 60s from UptimeRobot/cron/GitHub Actions so the web service stays awake.
# Daraja OAuth is also refreshed in-process every ~12 minutes when ENABLE_SCHEDULER/production scheduler runs (does not wake a sleeping instance).
