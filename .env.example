# Database (required for pnpm db:push and app startup)
DATABASE_URL=mysql://user:password@localhost:3306/paeds_resus

# App auth/runtime (minimum local placeholders)
JWT_SECRET=replace-with-a-long-random-string
VITE_APP_ID=local-dev-app
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im

# Optional local owner metadata
OWNER_NAME=Local Admin
OWNER_OPEN_ID=local-open-id
