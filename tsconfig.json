{
  "include": [
    "client/src/**/*",
    "shared/**/*",
    "server/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "client/src/components/AddStaffForm.tsx",
    "client/src/components/AdminNotificationsDashboard.tsx",
    "client/src/components/BulkStaffImport.tsx",
    "client/src/components/CertificateManagement.tsx",
    "client/src/components/CommunityInsights.tsx",
    "client/src/components/ConditionRecommendation.tsx",
    "client/src/components/CourseAssignmentModal.tsx",
    "client/src/components/FellowshipProgressCard.tsx",
    "client/src/components/MpesaEnrollmentModal.tsx",
    "client/src/components/NotificationPreferences.tsx",
    "client/src/components/ProviderIntelligenceDashboard.tsx",
    "client/src/components/RoleManagement.tsx",
    "client/src/components/StaffProgressTable.tsx",
    "client/src/components/ConditionHeatmap.tsx",
    "client/src/pages/AdminCoursesPanel.tsx",
    "client/src/pages/CourseCatalog.tsx",
    "client/src/pages/KaizenDashboard.tsx",
    "server/lib/facility-report-pdf.ts",
    "server/routers/community-insights.ts",
    "server/routers/condition-recommendation-ai.ts",
    "server/routers/provider-intelligence.ts"
  ],
  "compilerOptions": {
    "incremental": false,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "target": "ESNext",
    "strict": true,
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": [
      "node",
      "vite/client"
    ],
    "paths": {
      "@/*": [
        "./client/src/*"
      ],
      "@shared/*": [
        "./shared/*"
      ]
    }
  }
}
